# wired WebTransport chat sample. libc-free, x86_64-linux only.
# Mirrors examples/word_list/justfile; its ninja target is registered in the
# SDK's scripts/gen_ninja.sh alongside word_list's.

# Build the server against the SDK static library, after the SDK's own
# fmt+ninja+lint gate. The static, freestanding binary needs no libc.
build:
    cd ../.. && just build && ninja examples/webtransport_chat/wired_server

# Build and run (binds 0.0.0.0:4433; Ctrl-C to stop).
run: build
    ./wired_server

# Build and run over AF_XDP instead of a plain UDP socket (root required;
# same flags as examples/word_list, see README.md).
run-xdp: build
    sudo ./wired_server --ifindex $IFINDEX --ip $IP --san-ipv4 $IP --skb-mode

# Serve the frontend for local development (http://localhost:8000/).
# localhost is a secure context, so WebTransport works over plain HTTP here.
serve-frontend:
    cd public && python3 -m http.server 8000

# Serve the frontend over TLS (https://<host>:8443/) for access from another
# machine: a non-localhost http:// page is not a secure context and the
# browser disables the WebTransport API entirely. Needs public/cert.pem and
# public/key.pem (self-signed is fine; accept the browser warning once).
serve-frontend-tls:
    cd public && python3 -c "\
    import http.server, ssl; \
    srv = http.server.HTTPServer(('0.0.0.0', 8443), http.server.SimpleHTTPRequestHandler); \
    ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER); \
    ctx.load_cert_chain('cert.pem', 'key.pem'); \
    srv.socket = ctx.wrap_socket(srv.socket, server_side=True); \
    print('https://0.0.0.0:8443/'); \
    srv.serve_forever()"
