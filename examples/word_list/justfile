# wired real-UDP server sample. libc-free, x86_64-linux only.

cc := "clang"
cflags := "-target x86_64-linux-gnu -ffreestanding -fno-stack-protector -fno-builtin -nostdlib -static -O2 -Isrc"

# Build the server against the SDK static library (just build runs the SDK's
# own fmt+ninja+lint gate before archiving; sys.o is excluded from the
# archive, we supply our own _start). The static, freestanding binary needs
# no libc.
build:
    cd ../.. && just build && just lib && {{cc}} {{cflags}} \
        examples/word_list/wired_server.c \
        build/libwired.a \
        -o examples/word_list/wired_server

# Debug build: timestamped trace logging via -DQUIC_DEBUG. Compiles the SDK
# from source so the flag reaches the in-SDK trace points (the release
# library is built without it).
build-debug:
    cd ../.. && {{cc}} {{cflags}} -DQUIC_DEBUG \
        examples/word_list/wired_server.c \
        $(find src -name '*.c' ! -path 'src/common/platform/sys/sys.c') \
        -o examples/word_list/wired_server

# Build and run (binds 0.0.0.0:4433; Ctrl-C to stop).
run: build
    ./wired_server

# Debug build and run (with trace logging).
run-debug: build-debug
    ./wired_server
