# wired HTTP/3 server sample. libc-free, x86_64-linux only. One binary, four
# I/O drivers selected by CLI flag at startup (plain UDP / multi-worker /
# multi-thread / AF_XDP, see README.md). Both build targets (release, debug) are ninja
# targets in the SDK's build.ninja (see scripts/gen_ninja.sh); this justfile
# is just the entry point.

# Build the server against the SDK static library, after the SDK's own
# fmt+ninja+lint gate. The static, freestanding binary needs no libc.
build:
    cd ../.. && just build && ninja examples/word_list/wired_server

# Debug build: timestamped trace logging via -DQUIC_DEBUG. Compiles the SDK
# from source so the flag reaches the in-SDK trace points (the release
# library is built without it).
build-debug:
    cd ../.. && just gen-ninja && ninja examples/word_list/wired_server_debug

# Build and run (binds 0.0.0.0:4433; Ctrl-C to stop).
run: build
    ./wired_server

# Debug build and run (with trace logging).
run-debug: build-debug
    ./wired_server_debug

# Build and run with 4 worker processes, one pinned per CPU core
# (tasks/core-pinning-plan.md). fork + SO_REUSEPORT, not threads.
run-workers: build
    ./wired_server --workers 4 --pin-cores 1

# Build and run over AF_XDP instead of a plain UDP socket (root required;
# tasks/xdp-driver-plan.md). See README.md for the veth+netns interop recipe
# and the full flag list.
run-xdp: build
    sudo ./wired_server --ifindex $IFINDEX --queue 0 --ip $IP --port 4433 --cert cert.pem --key key.pem
