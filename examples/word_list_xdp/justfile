# wired AF_XDP real-NIC server sample. libc-free, x86_64-linux only, root
# required to run (raw AF_XDP socket + BPF prog load).

# Build against the SDK static library, after the SDK's own fmt+ninja+lint
# gate (same pattern as the other examples' justfiles).
build:
    cd ../.. && just build && ninja examples/word_list_xdp/wired_server

# Build and run (root required). See README.md for required flags and the
# veth+netns interop recipe.
run: build
    sudo ./wired_server --ifindex $IFINDEX --queue 0 --ip $IP --port 4433 --cert cert.pem --key key.pem
