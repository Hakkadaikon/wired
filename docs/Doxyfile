# Doxygen config for the wired public SDK reference.
# INPUT is intentionally absent: `just docs` derives it from wired.h's
# transitive includes and appends it on stdin, so the documented set can
# never drift from the real public API surface.

PROJECT_NAME           = wired
PROJECT_BRIEF          = "libc-free QUIC/HTTP3 SDK in C for x86_64-linux"
OUTPUT_DIRECTORY       = docs/sdk
GENERATE_HTML          = YES
HTML_OUTPUT            = .
GENERATE_LATEX         = NO
OPTIMIZE_OUTPUT_FOR_C  = YES
JAVADOC_AUTOBRIEF      = YES
EXTRACT_ALL            = NO
EXTRACT_STATIC         = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = YES
HAVE_DOT               = NO
STRIP_FROM_PATH        = src
FULL_PATH_NAMES        = YES
QUIET                  = YES
